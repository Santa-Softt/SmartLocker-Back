###############################################################################
# SMARTLOCKR APPLICATION ENVIRONMENT VARIABLES                                #
#                                                                             #
# This file serves as a template for environment-specific configurations.     #
# Copy this file to '.env' and fill in the required values.                   #
###############################################################################

# =============================================================================
# SPRING PROFILES
# =============================================================================
# Active Spring profiles (e.g., dev, prod, test)
# Optional. Default: dev (if not set in Spring)
SPRING_PROFILES_ACTIVE=dev

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Full JDBC URL for the PostgreSQL database
# Required for 'prod'. Default in 'dev': jdbc:postgresql://localhost:5432/santasoft
DATABASE_URL=jdbc:postgresql://localhost:5432/santasoft

# Database authentication credentials
# Required for 'prod'. Default in 'dev': postgres / admin
DATABASE_USER=postgres
DATABASE_PASSWORD=admin

# =============================================================================
# SECURITY & AUTHENTICATION (IAM)
# =============================================================================

# --- JWT Configuration ---
# Base64 encoded 512-bit secret key for JWT signing
# Required. Generation: openssl rand 64 | base64 | tr '+/' '-_' | tr -d '\n'
JWT_SECRET_KEY=your_base64_secret_key

# JWT token metadata
# Optional. Defaults: smartlockr-app / santasoft-api
JWT_AUDIENCE=smartlockr-app
JWT_ISSUER=santasoft-api

# JWT Expiration Time (ISO 8601 Duration format)
# e.g., 30m, 1h, 1d. Required.
JWT_EXPIRATION_TIME=30m

# --- Refresh Token Configuration ---
# Minimum byte size recommended: 32. Required.
REFRESHTOKEN_BYTE_SIZE=32
# Refresh token expiration (ISO 8601 Duration format). Required.
REFRESHTOKEN_EXPIRATION_TIME=7d

# --- OAuth2 Configuration ---
# Google OAuth2 Credentials
# Required for social login functionality
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# URI to redirect the user after successful OAuth2 authentication
# Required. Example: http://localhost:3000/home
OAUTH_REDIRECT_URI=http://localhost:3000/home

# =============================================================================
# INFRASTRUCTURE & BACKEND SETTINGS
# =============================================================================

# --- CORS Configuration ---
# Comma-separated list of allowed origins
# Required. Example: http://localhost:3000,https://app.santasoft.com
ALLOWED_ORIGINS=http://localhost:3000

# --- Redis Configuration ---
# Required for caching and idempotency locks
# Defaults: localhost / 6379
REDIS_HOST=localhost
REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=your_redis_password

# Time-to-live for idempotency locks (in hours)
# Optional. Default: 24
REDIS_IDEMPOTENCY_LOCK_TTL_HOURS=24

# --- Cookie Settings ---
# Secure: true/false. SameSite: Lax, Strict, None. Required.
COOKIES.SECURE=true
COOKIES.SAMESITE=Lax

# --- Business Logic ---
# Main system administrator email
# Required for administrative tasks/notifications
ADMIN_EMAIL=admin@santasoft.com

# --- API Documentation ---
# Enable GraphiQL public interface (true/false)
# Optional. Usually 'true' for dev, 'false' for prod.
DEV_GRAPHIQL=true

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# --- MercadoPago (Payment Gateway) ---
# All values are required if payment module is used
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-access-token
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret
MERCADOPAGO_WEBHOOK_URL=https://your-domain.com/webhooks/mercadopago
MERCADOPAGO_BACK_URL_SUCCESS=http://localhost:3000/payment/success
MERCADOPAGO_BACK_URL_FAILURE=http://localhost:3000/payment/failure

# =============================================================================
# ASYNC & WORKER CONFIGURATION
# =============================================================================
# Webhook executor thread pool settings
# Optional. Defaults: 4 / 8 / 100 / 60
ASYNC_WEBHOOK_CORE_POOL_SIZE=4
ASYNC_WEBHOOK_MAX_POOL_SIZE=8
ASYNC_WEBHOOK_QUEUE_CAPACITY=100
ASYNC_WEBHOOK_AWAIT_TERMINATION_SECONDS=60